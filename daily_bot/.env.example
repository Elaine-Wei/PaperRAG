# 复制为 .env 并填入真实值（.env 不要提交到 git）
# LLM relay（OpenAI 兼容）的 API key —— 从环境变量读取，绝不硬编码
RELAY_API_KEY=

# 以下均有默认值，一般无需修改
# RELAY_BASE_URL=https://a6.a6api.com/v1
# RELAY_MODEL=claude-fable-5

# 企业微信群机器人 webhook（top-30 链接消息 / 按篇推送）；空则跳过推送
WECOM_WEBHOOK_URL=

# 腾讯云 COS（top-30 概览/深读上传 + 30 天预签名下载链接）；私有桶，子账号仅可读写 COS_PREFIX 下
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-hongkong
COS_BUCKET=quantsociety-cold-data-1425188104
COS_PREFIX=paper_rag/
