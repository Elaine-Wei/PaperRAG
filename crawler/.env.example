# 复制为 crawler/.env 并填入真实值（.env 已在 .gitignore，不要提交）
# config.py 启动时会自动读取本目录下的 .env（setdefault：shell 已导出的变量优先）

# 数据库连接串
DATABASE_URL=postgresql://user:password@localhost:5432/papers_db

# OpenAlex（替代原 Semantic Scholar）：现在需要 API key（免费，约 $1/天额度）。
# 每个请求都会带上 api_key 和 mailto。
OPENALEX_API_KEY=
OPENALEX_MAILTO=your_email@example.com
